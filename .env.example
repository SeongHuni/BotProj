DISCORD_TOKEN=PUT_DISCORD_BOT_TOKEN_HERE
DISCORD_GUILD_ID=PUT_DISCORD_SERVER_ID_HERE
VERIFY_CHANNEL_ID=PUT_VERIFY_CHANNEL_ID_HERE

# If true, users can DM the bot with only their Minecraft nickname.
# Example DM: Steve
ALLOW_DM_VERIFY=true

# User-friendly default: /verify adds whitelist immediately.
# Set true to send requests to APPROVAL_CHANNEL_ID with approve/reject buttons.
REQUIRE_ADMIN_APPROVAL=false
APPROVAL_CHANNEL_ID=

# Optional. Whitelist add success logs are sent to this Discord channel.
WHITELIST_LOG_CHANNEL_ID=1508093161329660116

# Optional. If set, the bot grants this role after successful verification.
VERIFIED_ROLE_ID=

RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=PUT_STRONG_RCON_PASSWORD_HERE

MINECRAFT_SERVER_IP=34.64.135.102
MINECRAFT_SERVER_PORT=25565